{
  "name": "@jsonlee_12138/otcc",
  "type": "module",
  "version": "0.1.3",
  "description": "Claude Plugin - Prompt Engineering & CLI Tool",
  "bin": {
    "otcc": "./dist/index.mjs"
  },
  "oclif": {
    "bin": "otcc",
    "topicSeparator": " ",
    "commands": {
      "strategy": "pattern",
      "target": "./dist/commands",
      "globPatterns": [
        "**/*.{js,mjs,cjs}"
      ]
    }
  },
  "files": [
    "dist/",
    "templates/"
  ],
  "scripts": {
    "build": "tsdown && cp -r templates dist/",
    "typecheck": "tsc --noEmit",
    "dev": "bun run src/index.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky",
    "test": "bun test",
    "tag": "bun run scripts/tag.ts",
    "release": "bun run scripts/release.ts"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  },
  "dependencies": {
    "@oclif/core": "^4.10.3",
    "inquirer": "^13.3.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/bun": "^1.3.12",
    "commitizen": "^4.3.1",
    "cz-git": "^1.12.0",
    "esbuild": "^0.27.4",
    "eslint": "^10.1.0",
    "eslint-plugin-format": "^2.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsdown": "^0.21.6"
  }
}
